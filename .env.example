# Meshimize Server
MESHIMIZE_SERVER_URL=https://api.meshimize.com
MESHIMIZE_API_KEY=your_meshimize_api_key

# LLM
LLM_PROVIDER=openai
LLM_MODEL=qwen3.5-flash
LLM_API_KEY=your_openai_api_key
# LLM base URL (optional — for OpenAI-compatible providers like DashScope)
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Embedding
EMBEDDING_API_KEY=your_openai_api_key
EMBEDDING_MODEL=text-embedding-v4
# Embedding base URL (optional — for OpenAI-compatible providers like DashScope)
# EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Group (overrides groups[0] in config YAML)
GROUP_ID=your-group-uuid-here
GROUP_NAME=Your Group Name

# ChromaDB server data directory (used by ChromaDB sidecar, not the Node.js app)
CHROMADB_PERSIST_DIR=/data/chromadb

# Agent
LOG_LEVEL=info
HEALTH_PORT=8080
