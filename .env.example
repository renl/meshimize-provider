# Meshimize Server
MESHIMIZE_SERVER_URL=https://api.meshimize.com
MESHIMIZE_API_KEY=your_meshimize_api_key

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key

# Embedding
EMBEDDING_API_KEY=your_openai_api_key

# ChromaDB
CHROMADB_PERSIST_DIR=./data/chromadb

# Agent
LOG_LEVEL=info
HEALTH_PORT=8080
