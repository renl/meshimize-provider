{
  "name": "meshimize-provider",
  "version": "0.1.0",
  "description": "Meshimize Seed Provider Agent — RAG-powered Q&A responder",
  "main": "dist/index.js",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "ingest": "node dist/index.js --ingest-only",
    "validate": "node dist/index.js --validate",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phoenix-channels": "^1.0.0",
    "langchain": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "chromadb": "^1.9.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0",
    "pino-pretty": "^13.0.0"
  }
}
